migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local dev credentials - never commit
.env

# Reference clone of the original web dashboard (used only to source
# icons/fonts/backgrounds during development) - not part of this app.
/reference_hemma/

# Desktop scaffold used only for local dev verification (screenshots
# without a physical tablet). Android is the only shipped target (see
# CLAUDE.md) - regenerate with `flutter create --platforms=linux .` if
# needed again.
/linux/

# Release signing - keep the keystore and its passwords out of the repo.
# Losing these breaks the in-app update chain: BACK THEM UP.
/android/key.properties
/android/keys/

# Local assistant/tooling state
/.claude/
